{% extends "layout.html.twig" %}

{% block title %}{{ gallery.title }}{% endblock %}

{% block navbar %}
<nav class="navbar navbar-expand-lg navbar-dark bg-primary">
    <div class="container-fluid">
        <a class="navbar-brand" href="galleries.php">Galerii</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" href="galleries.php">Lista galerii</a>
                </li>
            </ul>
            {% if session_username %}
                <ul class="navbar-nav">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown">
                            {{ session_username }}
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="logout.php">Logout</a></li>
                        </ul>
                    </li>
                </ul>
            {% endif %}
        </div>
    </div>
</nav>
{% endblock %}

{% block content %}
<div class="container mt-4">
    <div class="row">
        <div class="col-lg-8">
            <h1 class="mb-3">{{ gallery.title }}</h1>
            <p class="lead">{{ gallery.description }}</p>
            <p class="text-muted">Creat la: {{ gallery.created_at }}</p>

            <hr>

            <h2 class="mb-4">Imagini</h2>

            {% if images is not empty %}
                {% for img in images %}
                    <div class="card shadow-sm mb-4">
                        <div class="card-body">
                            <img src="{{ img.image_url }}"
                                 alt="{{ img.alt_text }}"
                                 class="img-fluid rounded shadow-sm mb-3">

                            <h5 class="mb-3">Comentarii pentru aceasta imagine ({{ img.comments|length }})</h5>

                            {% if img.comments is not empty %}
                                {% for c in img.comments %}
                                    <div class="mb-3 pb-3 border-bottom">
                                        <h6 class="mb-1">{{ c.author_name }}</h6>
                                        <small class="text-muted d-block mb-2">{{ c.created_at }}</small>
                                        <p class="mb-0">{{ c.content }}</p>
                                    </div>
                                {% endfor %}
                            {% else %}
                                <p class="text-muted">Nu exista comentarii pentru aceasta imagine.</p>
                            {% endif %}

                            {% if session_user_id %}
                                <form method="post" class="mt-3">
                                    <input type="hidden" name="image_id" value="{{ img.id }}">
                                    <div class="mb-3">
                                        <textarea name="content" class="form-control" rows="3" placeholder="Scrie un comentariu..." required></textarea>
                                    </div>
                                    <button type="submit" class="btn btn-primary">Adauga comentariu</button>
                                </form>
                            {% else %}
                                <div class="alert alert-warning mt-3 mb-0">
                                    Trebuie sa fii logat pentru a adauga comentarii. <a href="login.php" class="alert-link">Login</a>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            {% else %}
                <div class="alert alert-info">Nu exista imagini pentru aceasta galerie.</div>
            {% endif %}
        </div>
    </div>

    <div class="mt-4">
        <a href="galleries.php" class="btn btn-outline-primary">&larr; Inapoi la galerii</a>
    </div>
</div>
{% endblock %}